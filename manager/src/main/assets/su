#!/system/bin/sh

# Shizuku+ SU Bridge (su wrapper)
# Allows legacy root apps to function via Shizuku+ privileges.
# Drop-in replacement for /system/bin/su for apps that support custom paths.

BASEDIR=$(dirname "$0")

# Do NOT hardcode RISH_APPLICATION_ID here. rish must authenticate as the *calling* app (the one
# that ran this su), because the Shizuku+ server rejects a package that doesn't belong to the
# calling UID. rish derives the calling app's package from the process tree when it's unset, so a
# hardcoded value here (previously af.shizuku.plus.api) would break the bridge for every app except
# Shizuku+ itself. Leave it unset and let rish resolve it — unless the caller already exported one.

# If no arguments are provided, drop into an interactive rish shell
if [ $# -eq 0 ]; then
    exec sh "$BASEDIR/rish"
fi

# Handle common 'su -c' usage patterns
COMMAND=""
while [ $# -gt 0 ]; do
    case "$1" in
        -c)
            shift
            COMMAND="$1"
            shift
            ;;
        *)
            # Ignore other flags (like -s, --user, etc) for now as rish 
            # handles the environment.
            shift
            ;;
    esac
done

if [ -n "$COMMAND" ]; then
    # Execute the command via rish
    exec sh "$BASEDIR/rish" -c "$COMMAND"
else
    # Fallback: pass all original arguments if -c wasn't used
    exec sh "$BASEDIR/rish" "$@"
fi
