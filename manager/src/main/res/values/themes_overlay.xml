    <!-- Ocean Accent Overlay -->
    <style name="ThemeOverlay.Accent.Ocean">
        <item name="colorPrimary">#0288D1</item>
        <item name="colorPrimaryContainer">#E1F5FE</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorOnPrimaryContainer">#01579B</item>
    </style>
    <style name="ThemeOverlay.Accent.Ocean.Dark">
