        <item name="colorPrimary">#00796B</item>
        <item name="colorPrimaryContainer">#E0F2F1</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorOnPrimaryContainer">#004D40</item>
    </style>
    <style name="ThemeOverlay.Accent.Green.Dark">
