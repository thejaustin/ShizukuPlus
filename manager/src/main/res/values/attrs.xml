<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="appColorPrimary" format="reference" />

    <!-- EmptyStateView custom attributes -->
    <attr name="emptyIcon" format="reference" />
    <attr name="emptyTitle" format="reference" />
    <attr name="emptyDescription" format="reference" />
    <attr name="emptyActionText" format="reference" />

    <declare-styleable name="EmptyStateView">
        <attr name="emptyIcon" />
        <attr name="emptyTitle" />
        <attr name="emptyDescription" />
        <attr name="emptyActionText" />
    </declare-styleable>

    <declare-styleable name="PlusFeaturePreference">
        <attr name="infoTitle" format="reference|string" />
        <attr name="infoDetail" format="reference|string" />
        <attr name="badgeType" format="enum">
            <enum name="none" value="0" />
            <enum name="plus" value="1" />
            <enum name="root" value="2" />
            <enum name="experimental" value="3" />
        </attr>
    </declare-styleable>
</resources>

