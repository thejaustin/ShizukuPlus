<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:title="Capabilities"
        app:collapsible="false">

        <af.shizuku.manager.settings.PlusNavPreference
            android:key="nav_shizuku_plus"
            android:title="Feature Hub"
            android:summary="Manage exclusive Plus capabilities"
            android:icon="@drawable/ic_bolt_24"
            android:fragment="af.shizuku.manager.settings.ShizukuPlusSettingsFragment" />

        <af.shizuku.manager.settings.PlusNavPreference
            android:key="nav_root_integration"
            android:title="Root &amp; Compatibility"
            android:summary="ADB connection, SU bridge, rootless integration, and stock Shizuku compatibility"
            android:icon="@drawable/ic_shield_24"
            android:fragment="af.shizuku.manager.settings.RootIntegrationSettingsFragment" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:title="Personalization"
        app:collapsible="false">

        <Preference
            android:key="nav_personalization"
            android:title="Appearance"
            android:summary="Theme, shapes, icons, motion, home layout, and language"
            android:icon="@drawable/ic_palette_24"
            android:fragment="af.shizuku.manager.settings.PersonalizationSettingsFragment" />

        <Preference
            android:key="nav_app_management"
            android:title="App Interactions"
            android:summary="Gestures, long-press actions, and install verification"
            android:icon="@drawable/ic_devices_24"
            android:fragment="af.shizuku.manager.settings.AppManagementSettingsFragment" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:title="System"
        app:collapsible="false">

        <Preference
            android:key="nav_behavior"
            android:title="Startup &amp; Behavior"
            android:summary="Boot options, watchdog, network, and activity status"
            android:icon="@drawable/ic_settings_suggest_24"
            android:fragment="af.shizuku.manager.settings.BehaviorSettingsFragment" />

        <Preference
            android:key="nav_advanced"
            android:title="Advanced &amp; Diagnostics"
            android:summary="Logs, ADB tools, and troubleshooting"
            android:icon="@drawable/ic_terminal_24"
            android:fragment="af.shizuku.manager.settings.AdvancedSettingsFragment" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:title="About"
        app:collapsible="false">

        <Preference
            android:key="nav_about"
            android:title="About"
            android:summary="Version, licenses, and updates"
            android:icon="@drawable/ic_info_24"
            android:fragment="af.shizuku.manager.settings.AboutSettingsFragment" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

</PreferenceScreen>
