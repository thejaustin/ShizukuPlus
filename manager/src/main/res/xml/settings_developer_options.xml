<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Backup & Restore -->
    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_backup"
        android:title="@string/settings_backup_category"
        android:defaultValue="false">

        <Preference
            android:key="export_settings"
            android:title="@string/settings_export_title"
            android:summary="@string/settings_export_summary"
            android:icon="@drawable/ic_outline_arrow_upward_24" />

        <Preference
            android:key="import_settings"
            android:title="@string/settings_import_title"
            android:summary="@string/settings_import_summary"
            android:icon="@drawable/ic_outline_arrow_downward_24" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_debug"
        android:title="Debug &amp; Diagnostics"
        android:defaultValue="true">

        <Preference
            android:key="manual_report"
            android:title="@string/manual_report_title"
            android:summary="@string/manual_report_summary"
            android:icon="@drawable/ic_server_error_24" />

        <Preference
            android:key="manual_db_recovery"
            android:title="Manual Database Recovery"
            android:summary="Attempt to salvage corrupted Activity Logs using advanced methods (.dump, .recover, or Raw Text Extraction). Use if automatic recovery failed."
            android:icon="@drawable/ic_history_24" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>







    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_dangerous_experimental"
        android:title="Dangerous &amp; Experimental Settings"
        android:defaultValue="false">

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="bootloader_flash_ota_enabled"
            android:title="[DANGEROUS] Systemless OTA Flashing"
            android:summary="Use android.os.UpdateEngine via Shizuku shell to seamlessly install zip payloads to the inactive slot without custom recovery. DANGER: Flashing incompatible payloads WILL result in a hard brick or bootloop."
            android:icon="@drawable/ic_update_24"
            android:defaultValue="false" />
            
        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="bootloader_fastbootd_reboot_enabled"
            android:title="[Experimental] Fastbootd &amp; Recovery Bridging"
            android:summary="Allow root apps to physically trigger bootloader, fastbootd, and recovery reboots natively using Android's RecoverySystem APIs."
            android:icon="@drawable/ic_server_restart"
            android:defaultValue="false" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

</PreferenceScreen>
