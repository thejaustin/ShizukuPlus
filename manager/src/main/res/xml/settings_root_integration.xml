<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <SwitchPreferenceCompat
        android:key="adb_proxy_enabled"
        android:title="@string/settings_adb_proxy"
        android:summary="@string/settings_adb_proxy_summary"
        android:icon="@drawable/ic_wadb_24"
        android:defaultValue="false" />

    <SwitchPreferenceCompat
        android:key="on_device_adb_tcp"
        android:title="@string/settings_on_device_adb_tcp"
        android:summary="@string/settings_on_device_adb_tcp_summary"
        android:icon="@drawable/ic_adb_24"
        android:defaultValue="false" />

    <SwitchPreferenceCompat
        android:key="force_start_wadb"
        android:title="@string/settings_force_start_wadb"
        android:summary="@string/settings_force_start_wadb_summary"
        android:icon="@drawable/ic_server_restart"
        android:defaultValue="false" />

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_su_bridge"
        android:title="SU Bridge Configuration"
        android:defaultValue="true">

        <SwitchPreferenceCompat
            android:key="su_bridge_enabled"
            android:title="@string/settings_fake_su"
            android:summary="@string/settings_fake_su_summary"
            android:icon="@drawable/ic_root_24"
            android:defaultValue="false" />

        <af.shizuku.manager.settings.SUBridgeDiagramPreference
            android:key="su_bridge_diagram" />

        <EditTextPreference
            android:key="custom_su_path"
            android:title="Custom SU Path"
            android:summary="Set a custom path for the su binary spoofing (e.g., /system/xbin/su). Leave blank for default."
            android:dependency="su_bridge_enabled"
            android:icon="@drawable/ic_terminal_24"
            app:iconSpaceReserved="true"
            android:singleLine="true" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <Preference
        android:key="root_compatibility_hub"
        android:title="@string/settings_root_integration_hub"
        android:summary="@string/settings_root_integration_hub_summary"
        android:icon="@drawable/ic_admin_panel_settings_24" />

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_root_modules"
        android:title="Rootless Bridges"
        android:defaultValue="true">

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="root_build_prop_redirect_enabled"
            android:title="build.prop Redirection"
            android:summary="Redirect system build property modifications to a writable proxy file rootless"
            android:icon="@drawable/ic_settings_suggest_24"
            android:defaultValue="false"
            app:infoTitle="build.prop Redirection Explainer"
            app:infoDetail="This module automatically shadow-copies the original build.prop to a user-writable path and redirects all writes to it, allowing tweakers to safely modify system values rootless." />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="root_auto_grant_enabled"
            android:title="@string/settings_root_auto_grant"
            android:summary="@string/settings_root_auto_grant_summary"
            android:icon="@drawable/ic_admin_panel_settings_24"
            android:defaultValue="false"
            app:infoTitle="@string/help_root_auto_grant_title"
            app:infoDetail="@string/help_root_auto_grant_detail" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="root_file_interceptor_enabled"
            android:title="@string/settings_root_file_interceptor"
            android:summary="@string/settings_root_file_interceptor_summary"
            android:icon="@drawable/ic_folder_24"
            android:defaultValue="false"
            app:infoTitle="@string/help_root_file_interceptor_title"
            app:infoDetail="@string/help_root_file_interceptor_detail" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_ghost_bridge"
        android:title="Mocking &amp; Simulation"
        android:defaultValue="false">

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="root_iptables_mocking_enabled"
            android:title="Firewall Success Mocking"
            android:summary="Intercept and fake success for iptables rules when local netfilter permissions fail"
            android:icon="@drawable/ic_shield_24"
            android:defaultValue="false"
            app:infoTitle="Firewall Mocking Explainer"
            app:infoDetail="Fakes execution success for iptables commands when rootless limitations prevent real rules from being set, letting firewall apps continue functioning." />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="root_magisk_mocking_enabled"
            android:title="@string/settings_root_magisk_mocking"
            android:summary="@string/settings_root_magisk_mocking_summary"
            android:icon="@drawable/ic_settings_suggest_24"
            android:defaultValue="false"
            app:infoTitle="@string/help_root_magisk_title"
            app:infoDetail="@string/help_root_magisk_detail" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="root_busybox_mocking_enabled"
            android:title="@string/settings_root_busybox_mocking"
            android:summary="@string/settings_root_busybox_mocking_summary"
            android:icon="@drawable/ic_terminal_24"
            android:defaultValue="false"
            app:infoTitle="@string/help_root_busybox_title"
            app:infoDetail="@string/help_root_busybox_detail" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="overlay_fs_proxy_enabled"
            android:title="OverlayFS System Ghosting"
            android:summary="[Developer] Seamlessly mount virtual overlay filesystems to simulate rw /system for root apps. Warning: Highly experimental."
            android:icon="@drawable/ic_folder_24"
            android:defaultValue="false" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="root_kernel_ghosting_enabled"
            android:title="Kernel Driver Ghosting"
            android:summary="[Developer] Silently simulate success for insmod/rmmod kernel commands without loading the kernel modules."
            android:icon="@drawable/ic_settings_suggest_24"
            android:defaultValue="false" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="root_partition_ghosting_enabled"
            android:title="Partition Flash Ghosting"
            android:summary="[Developer] Intercept and fake 'dd' operations targeting /dev/block/. Prevents ROM flashers from crashing while doing nothing."
            android:icon="@drawable/ic_admin_panel_settings_24"
            android:defaultValue="false" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="root_power_ghosting_enabled"
            android:title="Power State Ghosting"
            android:summary="[Developer] Intercept reboot, recovery, and soft-reboot commands and silently ignore them to prevent unwanted device restarts."
            android:icon="@drawable/ic_server_restart"
            android:defaultValue="false" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_unlocked_bootloader"
        android:title="Bootloader Integration"
        android:defaultValue="false">

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="bootloader_flash_ota_enabled"
            android:title="Systemless OTA Flashing"
            android:summary="Flash OTA payloads to inactive slot without root or custom recovery"
            android:icon="@drawable/ic_update_24"
            android:defaultValue="false" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="bootloader_fastbootd_reboot_enabled"
            android:title="FastbootD Transition"
            android:summary="Restart directly into fastbootd user space from Shizuku shell"
            android:icon="@drawable/ic_server_restart"
            android:defaultValue="false" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

</PreferenceScreen>
