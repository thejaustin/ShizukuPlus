<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <af.shizuku.manager.settings.DiagnosticsDashboardPreference
        android:key="diagnostics_dashboard" />

    <!-- Core toggle: must be enabled for most Plus features to function -->
    <af.shizuku.manager.settings.PlusFeaturePreference
        android:key="custom_api_enabled"
        android:title="@string/settings_enhanced_api"
        android:summary="@string/settings_enhanced_api_summary"
        android:icon="@drawable/ic_code_24"
        android:defaultValue="true"
        app:badgeType="plus" />

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_connectivity"
        android:title="Networking &amp; Connectivity"
        android:defaultValue="false">

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="network_governor_plus_enabled"
            android:title="DNS Governor"
            android:summary="@string/settings_network_governor_plus_summary"
            android:icon="@drawable/ic_lan_24"
            android:defaultValue="true"
            app:infoTitle="@string/help_network_governor_plus_title"
            app:infoDetail="@string/help_network_governor_plus_detail"
            app:badgeType="plus" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="binder_firewall_enabled"
            android:title="@string/settings_binder_firewall"
            android:summary="@string/settings_binder_firewall_summary"
            android:icon="@drawable/ic_shield_24"
            android:defaultValue="false"
            app:badgeType="plus" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="continuity_bridge_enabled"
            android:title="Continuity Bridge"
            android:summary="@string/settings_continuity_bridge_summary"
            android:icon="@drawable/ic_devices_24"
            android:defaultValue="true"
            app:infoTitle="@string/help_continuity_bridge_title"
            app:infoDetail="@string/help_continuity_bridge_detail"
            app:badgeType="plus" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_system"
        android:title="System &amp; Performance"
        android:defaultValue="false">

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="activity_manager_plus_enabled"
            android:title="Process Control"
            android:summary="@string/settings_activity_manager_plus_summary"
            android:icon="@drawable/ic_bolt_24"
            android:defaultValue="true"
            app:infoTitle="@string/help_activity_manager_plus_title"
            app:infoDetail="@string/help_activity_manager_plus_detail"
            app:badgeType="plus" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="shell_interceptor_enabled"
            android:title="Shell Accelerator"
            android:summary="@string/settings_shell_interceptor_summary"
            android:icon="@drawable/ic_terminal_24"
            android:defaultValue="true"
            app:infoTitle="@string/help_shell_interceptor_title"
            app:infoDetail="@string/help_shell_interceptor_detail"
            app:badgeType="plus" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="avf_manager_enabled"
            android:title="VM Manager"
            android:summary="@string/settings_avf_manager_summary"
            android:icon="@drawable/ic_server_24"
            android:defaultValue="true"
            app:infoTitle="@string/help_avf_manager_title"
            app:infoDetail="@string/help_avf_manager_detail"
            app:badgeType="plus" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_security"
        android:title="Security &amp; Access"
        android:defaultValue="false">

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="dhizuku_mode"
            android:title="@string/settings_dhizuku_mode"
            android:summary="@string/settings_dhizuku_mode_summary"
            android:icon="@drawable/ic_admin_panel_settings_24"
            app:infoTitle="@string/help_dhizuku_title"
            app:infoDetail="@string/help_dhizuku_detail"
            app:badgeType="plus" />

        <!-- Only shown when app is active Device Owner; tapping clears DO status -->
        <Preference
            android:key="clear_device_owner"
            android:title="@string/settings_clear_device_owner"
            android:summary="@string/settings_clear_device_owner_summary"
            android:icon="@drawable/ic_delete_24"
            android:visible="false" />

        <af.shizuku.manager.settings.CollapsiblePreferenceCategory
            android:key="category_dhizuku_admin"
            android:title="Device Owner Tools"
            android:dependency="dhizuku_mode"
            android:defaultValue="false">

            <SwitchPreferenceCompat
                android:key="dhizuku_disable_screencap"
                android:title="Screen Capture Lockdown"
                android:summary="Disable screenshots and screen recordings globally across the device"
                android:icon="@drawable/ic_visibility_off_24"
                android:defaultValue="false" />

            <SwitchPreferenceCompat
                android:key="dhizuku_disallow_usb"
                android:title="USB Data Lockdown"
                android:summary="Disallow USB file transfer (MTP) and secure device physically"
                android:icon="@drawable/ic_shield_24"
                android:defaultValue="false" />

            <af.shizuku.manager.settings.AppPickerPreference
                android:key="dhizuku_suspended_packages"
                android:title="Suspended Applications"
                android:summary="Select applications to freeze and block from running completely"
                android:icon="@drawable/ic_science_24" />

        </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="shadow_binder_enabled"
            android:title="@string/settings_shadow_binder"
            android:summary="@string/settings_shadow_binder_summary"
            android:icon="@drawable/ic_science_24"
            android:defaultValue="false"
            app:badgeType="plus" />

        <af.shizuku.manager.settings.AppPickerPreference
            android:key="shadow_binder_hidden_packages"
            android:title="@string/settings_shadow_binder_hidden_packages"
            android:summary="@string/settings_shadow_binder_hidden_packages_summary"
            android:icon="@drawable/ic_visibility_24"
            android:dependency="shadow_binder_enabled" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_storage"
        android:title="Storage &amp; Files"
        android:defaultValue="false">

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="storage_proxy_enabled"
            android:title="Storage Bridge"
            android:summary="@string/settings_storage_proxy_summary"
            android:icon="@drawable/ic_folder_24"
            android:defaultValue="true"
            app:infoTitle="@string/help_storage_proxy_title"
            app:infoDetail="@string/help_storage_proxy_detail"
            app:badgeType="plus" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_backup"
        android:title="Backup &amp; Restore"
        android:defaultValue="false">

        <Preference
            android:key="backup_settings"
            android:title="Backup Settings"
            android:summary="Export your configurations and enhancements securely using Biometric encryption."
            android:icon="@drawable/ic_folder_24" />

        <Preference
            android:key="restore_settings"
            android:title="Restore Settings"
            android:summary="Restore your configurations from an encrypted backup."
            android:icon="@drawable/ic_install_24" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_developer"
        android:title="@string/settings_plus_category_developer"
        android:visible="false"
        android:defaultValue="false">

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="window_manager_plus_enabled"
            android:title="Window Tuner"
            android:summary="@string/settings_window_manager_plus_summary"
            android:icon="@drawable/ic_window_24"
            android:defaultValue="false"
            app:infoTitle="@string/help_window_manager_plus_title"
            app:infoDetail="@string/help_window_manager_plus_detail"
            app:badgeType="experimental" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="overlay_manager_plus_enabled"
            android:title="Theming Bridge"
            android:summary="@string/settings_overlay_manager_plus_summary"
            android:icon="@drawable/ic_palette_24"
            android:defaultValue="false"
            android:dependency="window_manager_plus_enabled"
            app:infoTitle="@string/help_overlay_manager_plus_title"
            app:infoDetail="@string/help_overlay_manager_plus_detail"
            app:badgeType="experimental" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="ai_core_plus_enabled"
            android:title="AI Bridge &amp; NPU"
            android:summary="@string/settings_ai_core_plus_summary"
            android:icon="@drawable/ic_integration_instructions_24"
            android:defaultValue="false"
            app:infoTitle="@string/help_ai_core_plus_title"
            app:infoDetail="@string/help_ai_core_plus_detail"
            app:badgeType="experimental" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="ai_core_master_enabled"
            android:title="AI Core Master"
            android:summary="Enable privileged AI operations: NPU scheduling and window hierarchy access"
            android:icon="@drawable/ic_integration_instructions_24"
            android:defaultValue="false"
            android:dependency="ai_core_plus_enabled"
            app:badgeType="experimental" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="npu_acceleration_enabled"
            android:title="NPU Acceleration"
            android:summary="Delegate AI inference tasks to the device Neural Processing Unit when available"
            android:icon="@drawable/ic_settings_suggest_24"
            android:defaultValue="false"
            android:dependency="ai_core_master_enabled"
            app:badgeType="experimental" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="native_window_crawler_enabled"
            android:title="Window Hierarchy Crawler"
            android:summary="Allow AI automation to read the active window view hierarchy without Accessibility Services"
            android:icon="@drawable/ic_code_24"
            android:defaultValue="false"
            android:dependency="ai_core_master_enabled"
            app:badgeType="experimental" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="ai_core_experimental_enabled"
            android:title="Experimental AI Automation"
            android:summary="Enable gesture simulation, pixel capture, and text injection for AI-driven automation"
            android:icon="@drawable/ic_science_24"
            android:defaultValue="false"
            android:dependency="ai_core_plus_enabled"
            app:badgeType="experimental" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="software_keystore_fallback_enabled"
            android:title="Software KeyStore Fallback"
            android:summary="[RISKY] Allows caching the ADB RSA Private Key encrypted with a software-based static AES key if your device's hardware KeyStore fails (e.g., Samsung Knox). Reduces pairing prompts but decreases security."
            android:icon="@drawable/ic_shield_24"
            android:defaultValue="false"
            app:badgeType="experimental" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="vector_enabled"
            android:title="@string/settings_vector_experimental"
            android:summary="@string/settings_vector_summary"
            android:icon="@drawable/ic_code_24"
            android:defaultValue="false"
            app:badgeType="experimental" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="experimental_root_compat"
            android:title="@string/settings_experimental_root_experimental"
            android:summary="@string/settings_experimental_root_summary"
            android:icon="@drawable/ic_science_24"
            android:defaultValue="false"
            app:badgeType="experimental" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="spoof_device_enabled"
            android:title="@string/settings_spoof_device_experimental"
            android:summary="@string/settings_spoof_device_summary"
            android:icon="@drawable/ic_smartphone_24"
            android:defaultValue="false"
            app:badgeType="experimental" />

        <rikka.preference.SimpleMenuPreference
            android:key="spoof_target"
            android:title="@string/settings_spoof_target"
            android:entries="@array/spoof_targets"
            android:entryValues="@array/spoof_targets_values"
            android:defaultValue="pixel_8_pro"
            android:summary="%s"
            android:icon="@drawable/ic_smartphone_24" />

        <af.shizuku.manager.settings.PlusFeaturePreference
            android:key="samsung_system_uid_escalation_enabled"
            android:title="Samsung System UID Escalation"
            android:summary="[DANGEROUS] Attempt to escalate to UID 1000 (system) using an exploit specific to unpatched Samsung devices (by pascua28). Use at your own risk."
            android:icon="@drawable/ic_warning_24"
            android:defaultValue="false"
            app:badgeType="root" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

</PreferenceScreen>
