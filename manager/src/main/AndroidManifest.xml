<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- Android 16+ Local Network Protection: on Android 17 (enforced) the mDNS discovery of the
         wireless-debugging service and the loopback socket ADB pairing/connect use are gated
         behind these, so without them the service can't be found/started and nothing works (#317).
         ACCESS_LOCAL_NETWORK / USE_LOOPBACK_INTERFACE are API 36 and this module compiles against
         SDK 35, but they're plain strings in the manifest and older OSes ignore unknown permissions. -->
    <uses-permission android:name="android.permission.ACCESS_LOCAL_NETWORK" />
    <uses-permission android:name="android.permission.USE_LOOPBACK_INTERFACE" />
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="33" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.DOWNLOAD_WITHOUT_NOTIFICATION" />

    <uses-permission
        android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!-- ${applicationId}-scoped: Plus and Dropin flavors share this manifest but have different
         applicationIds, and a permission-group name is not allowed to be redeclared by a second
         package - installing both side by side used to fail with error -126 ("attempting to
         redeclare permission group... already owned by...") (#316). Unlike the permission below,
         nothing outside this manifest references the group name by string, so scoping it is safe. -->
    <permission-group
        android:name="${applicationId}.permission-group.API"
        android:description="@string/permission_group_description"
        android:icon="@drawable/ic_system_icon"
        android:label="@string/permission_group_label" />

    <permission
        android:name="af.shizuku.plus.permission.MANAGER"
        android:protectionLevel="signature" />
    <uses-permission android:name="af.shizuku.plus.permission.MANAGER" />

    <!-- NOT flavor-scoped: this permission name is baked in as a literal constant in the
         client-facing api/provider library (ShizukuProvider.PERMISSION) that third-party apps
         compile against, so it must stay stable across flavors. -->
    <permission
        android:name="af.shizuku.plus.permission.API_V23"
        android:description="@string/permission_description"
        android:icon="@drawable/ic_system_icon"
        android:label="@string/permission_label"
        android:permissionGroup="${applicationId}.permission-group.API"
        android:protectionLevel="dangerous" />
    
    <!-- moe.shizuku.manager.permission.API_V23 is the permission every stock Shizuku-API client is
         hardcoded to (ShizukuProvider.PERMISSION); the server OS-grants it on authorize
         (updateFlagsForUid -> grantRuntimePermission), which silently fails unless some installed
         package DEFINES it. Its DEFINITION is flavor-scoped because the flavors have opposite
         constraints:
           - shizukuplus (af.shizuku.plus.api) can be installed BESIDE stock Shizuku, which owns this
             permission, so defining it here would fail install with -126 duplicate-permission (#316).
             src/shizukuplus/AndroidManifest.xml removes it; the separate Compat Hub (mutually
             exclusive with stock) is the definer for the Plus flavor.
           - dropin (moe.shizuku.privileged.api) IS the stock package-name replacement and is mutually
             exclusive with stock, so src/dropin/AndroidManifest.xml DEFINES it natively (dropin
             cannot host the Compat Hub — identical package name).
         The manager itself uses the permission in both flavors: -->
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />

    <application
        android:name=".ShizukuApplication"
        android:allowBackup="true"
        android:autoRevokePermissions="allowed"
        android:banner="@drawable/ic_launcher"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:directBootAware="true"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_descriptor"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:ignore="GoogleAppIndexingWarning"
        tools:remove="android:appComponentFactory"
        tools:targetApi="33">

        <meta-data android:name="io.sentry.dsn" android:value="${sentryDsn}" />
        <meta-data android:name="io.sentry.auto-init" android:value="false" />
        <meta-data android:name="io.sentry.traces-sample-rate" android:value="0.2" />
        <meta-data android:name="io.sentry.attach-screenshot" android:value="true" />
        <meta-data android:name="io.sentry.attach-view-hierarchy" android:value="true" />

        <!-- Main launcher activity -->
        <activity
            android:name=".MainActivity"
            android:banner="@mipmap/banner"
            android:exported="true"
            android:theme="@style/Theme.App.Starting" />

        <!-- Toggleable launcher alias — disabled by stealth mode -->
        <activity-alias
            android:name=".LauncherAlias"
            android:targetActivity=".MainActivity"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity-alias>

        <!-- Activity Aliases to fix broken shortcuts / task stack restoration -->
        <activity-alias
            android:name="af.shizuku.manager.home.HomeActivity"
            android:targetActivity=".MainActivity"
            android:exported="true" />
            
        <activity-alias
            android:name=".TvActivity"
            android:targetActivity=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name="af.shizuku.manager.ApplicationManagementActivity"
            android:targetActivity=".management.ApplicationManagementActivity"
            android:exported="true" />
        <activity-alias
            android:name="moe.shizuku.manager.ApplicationManagementActivity"
            android:targetActivity=".management.ApplicationManagementActivity"
            android:exported="true" />

        <!-- Settings Activity -->
        <activity
            android:name=".settings.SettingsActivity"
            android:exported="true"
            android:label="@string/settings_title"
            android:theme="@style/Theme">
            <intent-filter>
                <action android:name="android.intent.action.APPLICATION_PREFERENCES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".onboarding.OnboardingActivity"
            android:exported="false"
            android:label="@string/app_name" />
        <activity
            android:name=".home.SystemHubActivity"
            android:theme="@style/Theme"
            android:exported="false" />
            
        <activity
            android:name=".activitylog.ActivityLogActivity"
            android:theme="@style/Theme"
            android:exported="false"
            android:label="@string/settings_activity_log" />

        <activity
            android:name=".scripting.ScriptingActivity"
            android:theme="@style/Theme"
            android:exported="false"
            android:label="@string/scripting_title" />

        <activity
            android:name=".management.ApplicationManagementActivity"
            android:exported="false"
            android:label="@string/home_app_management_title" />

        <activity
            android:name=".settings.RootCompatibilityActivity"
            android:exported="false"
            android:label="@string/su_bridge_title" />
        <activity
            android:name=".settings.ServiceDoctorActivity"
            android:theme="@style/Theme"
            android:exported="false"
            android:label="@string/home_service_doctor_title" />
        <activity
            android:name=".shell.ShellTutorialActivity"
            android:exported="false"
            android:label="@string/home_terminal_title" />
        <activity
            android:name=".starter.StarterActivity"
            android:exported="true"
            android:label="@string/starter">
            <intent-filter>
                <action android:name="af.shizuku.manager.action.START_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".settings.BugReportDialogActivity"
            android:theme="@style/Theme.App.DialogHost"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:exported="false" />
        
        <activity
            android:name=".authorization.RequestPermissionActivity"
            android:directBootAware="true"
            android:excludeFromRecents="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL"
            android:theme="@style/GrantPermissions">
            <intent-filter>
                <action android:name="${applicationId}.intent.action.REQUEST_PERMISSION" />
                <action android:name="moe.shizuku.manager.intent.action.REQUEST_PERMISSION" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".legacy.ShellRequestHandlerActivity"
            android:directBootAware="true"
            android:excludeFromRecents="true"
            android:exported="true"
            android:theme="@style/GrantPermissions">
            <intent-filter android:priority="1000">
                <action android:name="rikka.shizuku.intent.action.REQUEST_BINDER" />
                <action android:name="${applicationId}.intent.action.REQUEST_BINDER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".legacy.LegacyIsNotSupportedActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:permission="af.shizuku.plus.permission.API_V23"
            android:theme="@style/GrantPermissions">
            <intent-filter>
                <action android:name="${applicationId}.intent.action.REQUEST_AUTHORIZATION" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- WorkManager's SystemForegroundService needs a declared foreground service type on Android 14+ -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="shortService"
            tools:node="merge" />

        <service
            android:name=".service.WatchdogService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Many apps rely on this app's API service for core functionality.
                    The API service can stop unexpectedly for various reasons (e.g., when connecting to Android Auto over USB).
                    This prevents the other apps from functioning properly.
                    The watchdog service would ensure the API is always available for the apps to use.
                    The watchdog service uses minimal resources and battery. There is no constant polling; it only reacts when the API service stops unexpectedly.
                    The watchdog service is opt-in and toggleable via settings, so users can choose to disable it at any time if not desired." />
        </service>

        <receiver
            android:name=".widget.ShizukuWidgetProvider"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="af.shizuku.manager.action.STATE_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <service
            android:name=".service.ShizukuTileService"
            android:exported="true"
            android:icon="@drawable/ic_server_ok_24"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
        </service>

        <service
            android:name=".service.AdbProxyService"
            android:exported="false" />

        <service
            android:name=".service.ShizukuLiveService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Displays a persistent status notification while the Shizuku bridge is active.
                    The service monitors the Shizuku binder state and shows or hides the notification accordingly.
                    It runs silently in the background when Shizuku is not active." />
        </service>

        <receiver
            android:name=".receiver.BinderRequestReceiver"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true"
            tools:ignore="ExportedReceiver">
            <intent-filter android:priority="1000">
                <action android:name="rikka.shizuku.intent.action.REQUEST_BINDER" />
                <action android:name="${applicationId}.intent.action.REQUEST_BINDER" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.BootCompleteReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.ManualStartReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="${applicationId}.START" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.ManualStopReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="${applicationId}.STOP" />
            </intent-filter>
        </receiver>

        <receiver android:name=".receiver.NotifAttemptReceiver" />
        <receiver android:name=".receiver.NotifCancelReceiver" />
        <receiver android:name=".receiver.NotifRestoreReceiver" />

        <!-- WorkManager is initialized manually via Configuration.Provider in ShizukuApplication.
             Removing WorkManagerInitializer here prevents the "already initialized" crash (#126). -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Authority is ${applicationId}.shizuku ONLY here. A content-provider authority is
             device-unique, so the coexist-with-stock Plus flavor (af.shizuku.plus.api) must NOT claim
             the stock authority moe.shizuku.privileged.api — doing so makes it fail to install
             (INSTALL_FAILED_CONFLICTING_PROVIDER, surfaced as "App not installed") whenever stock
             Shizuku, the Drop-In, or an old moe.shizuku.privileged.api Shizuku+ is present. The Drop-In
             flavor re-adds the stock authority in src/dropin/AndroidManifest.xml (it IS that package,
             so it's collision-safe); stock-client compat for the Plus flavor comes from the separate
             Compat Hub. -->
        <provider
            android:name=".ShizukuManagerProvider"
            android:authorities="${applicationId}.shizuku"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true"
            android:multiprocess="false"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <provider
            android:name=".DhizukuProvider"
            android:authorities="com.rosan.dhizuku;com.rosan.dhizuku.provider"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true"
            android:multiprocess="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        <receiver
            android:name=".admin.DhizukuAdminReceiver"
            android:description="@string/dhizuku_device_owner_desc"
            android:exported="true"
            android:label="@string/dhizuku_device_owner_label"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".adb.AdbPairingService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- ADB Pairing Tutorial (full-screen pairing flow for API 30+) -->
        <activity
            android:name=".adb.AdbPairingTutorialActivity"
            android:exported="false" />

        <!-- Legacy pairing: dialog-based code entry instead of notification RemoteInput -->
        <activity
            android:name=".adb.AdbPairingDialogActivity"
            android:theme="@style/Theme.App.DialogHost"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- Fake ADB Server -->
        <activity
            android:name=".adb.FakeAdbPairingActivity"
            android:theme="@android:style/Theme.DeviceDefault.Light.Dialog.Alert"
            android:excludeFromRecents="true"
            android:exported="false" />

        <service
            android:name="af.shizuku.manager.automation.AutomationService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Context-aware automation engine. Monitors Wi-Fi connectivity and the
                    foreground app so user-defined automation rules (e.g. auto-start the Shizuku bridge
                    on a trusted network) can react in real time. This must run continuously in the
                    background for the duration the user keeps automation enabled; dataSync's 6-hour
                    daily budget would silently stop it. It performs no constant polling beyond a light
                    foreground-app check and reacts to system network callbacks, so battery impact is
                    minimal, and it is toggleable via settings." />
        </service>

        <!-- Tasker/Locale-compatible automation plugin (#6): exposes start/stop as a plugin
             action and "service is running" as a plugin condition to any Locale-style host app
             (Tasker, MacroDroid, etc). -->
        <activity
            android:name="af.shizuku.manager.automation.locale.LocaleActionEditActivity"
            android:exported="true"
            android:icon="@drawable/ic_bolt_24"
            android:label="@string/automation_plugin_action_label"
            android:theme="@style/Theme.App.DialogHost">
            <intent-filter>
                <action android:name="com.twofortyfouram.locale.intent.action.EDIT_SETTING" />
            </intent-filter>
        </activity>

        <receiver
            android:name="af.shizuku.manager.automation.locale.LocaleActionFireReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.twofortyfouram.locale.intent.action.FIRE_SETTING" />
            </intent-filter>
        </receiver>

        <activity
            android:name="af.shizuku.manager.automation.locale.LocaleConditionEditActivity"
            android:exported="true"
            android:icon="@drawable/ic_bolt_24"
            android:label="@string/automation_plugin_condition_label"
            android:theme="@style/Theme.App.DialogHost">
            <intent-filter>
                <action android:name="com.twofortyfouram.locale.intent.action.EDIT_CONDITION" />
            </intent-filter>
        </activity>

        <receiver
            android:name="af.shizuku.manager.automation.locale.LocaleConditionQueryReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.twofortyfouram.locale.intent.action.QUERY_CONDITION" />
            </intent-filter>
        </receiver>

        <!-- AICore+ automation accessibility service. Restored: a modularity refactor
             (af6eca73) accidentally dropped this declaration, hiding it from Android's
             Accessibility settings (#305). -->
        <service
            android:name=".automation.AICorePlusService"
            android:label="@string/aicore_plus_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_automation" />
        </service>

        <!-- ADB pairing code auto-detection accessibility service (enabled on demand
             during pairing). Also dropped by af6eca73; restored alongside AICore+. -->
        <service
            android:name=".adb.AdbPairingAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>

</manifest>
